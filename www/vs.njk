<div class="vs-pair">
<h3>Show/hide with a when filter</h3>
<p class="desc"></p>
<div>
<div class="vs-label">hyperscript</div>

{% highlight "html" %}
<input _="on input
          show <li/> in #list
            when its textContent contains my value
            ignoring case" />
{% endhighlight %}
</div>
<div>
<div class="vs-label">JavaScript</div>

{% highlight "html" %}
<input id="filter" />
<script>
  document.getElementById("filter")
    .addEventListener("input", function() {
      const val = this.value.toLowerCase();
      document.querySelectorAll("#list li")
        .forEach(li => {
          li.style.display =
            li.textContent.toLowerCase()
              .includes(val) ? "" : "none";
        });
    });
</script>
{% endhighlight %}
</div>
