<div class="vs-pair">
<h3>Hide on click with a fade</h3>
<p class="desc"></p>
<div>
<div class="vs-label">hyperscript</div>

{% highlight "html" %}
<div _="on click transition my *opacity to 0
              then remove me">
  Click to dismiss
</div>
{% endhighlight %}
</div>
<div>
<div class="vs-label">JavaScript</div>

{% highlight "html" %}
<div id="msg">Click to dismiss</div>
<script>
  document.getElementById("msg")
    .addEventListener("click", function() {
      this.style.transition = "opacity 500ms";
      this.style.opacity = 0;
      this.addEventListener("transitionend", () => {
        this.remove();
      }, { once: true });
    });
</script>
{% endhighlight %}
</div>
