<div class="vs-pair">
<h3>Confirm before delete</h3>
<p class="desc"></p>
<div>
<div class="vs-label">hyperscript</div>

{% highlight "html" %}
<button _="on click
            answer 'Delete this item?' with 'Yes' or 'No'
            if it is 'Yes'
              fetch /api/items/${@data-id} with method:'DELETE'
              remove closest <tr/>">
  Delete
</button>
{% endhighlight %}
</div>
<div>
<div class="vs-label">JavaScript</div>

{% highlight "html" %}
<button class="delete-btn">Delete</button>
<script>
  document.querySelectorAll(".delete-btn")
    .forEach(btn => {
      btn.addEventListener("click", function() {
        if (!confirm("Delete this item?")) return;
        const row = this.closest("tr");
        const id = row.dataset.id;
        fetch("/api/items/" + id, { method: "DELETE" })
          .then(() => row.remove());
      });
    });
</script>
{% endhighlight %}
</div>
