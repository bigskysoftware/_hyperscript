<div class="vs-pair">
<h3>Toggle between two elements</h3>
<p class="desc"></p>
<div>
<div class="vs-label">hyperscript</div>

{% highlight "html" %}
<button _="on click toggle between
             .tabs-code and .tabs-preview
             on #panel">
  Switch View
</button>
{% endhighlight %}
</div>
<div>
<div class="vs-label">JavaScript</div>

{% highlight "html" %}
<button id="switch">Switch View</button>
<script>
  document.getElementById("switch")
    .addEventListener("click", function() {
      const panel = document.getElementById("panel");
      if (panel.classList.contains("tabs-code")) {
        panel.classList.remove("tabs-code");
        panel.classList.add("tabs-preview");
      } else {
        panel.classList.remove("tabs-preview");
        panel.classList.add("tabs-code");
      }
    });
</script>
{% endhighlight %}
</div>
