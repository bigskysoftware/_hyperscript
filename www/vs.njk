<div class="vs-pair">
<h3>Load content on scroll</h3>
<p class="desc"></p>
<div>
<div class="vs-label">hyperscript</div>

{% highlight "html" %}
<div id="sentinel"
     _="on intersection(intersecting) having threshold 0.1
          if intersecting
            fetch /api/more?page=${@data-page}
            put the result at end of #feed
            increment @data-page">
</div>
{% endhighlight %}
</div>
<div>
<div class="vs-label">JavaScript</div>

{% highlight "html" %}
<div id="sentinel"></div>
<script>
  let page = 1;
  const sentinel = document.getElementById("sentinel");
  const observer = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) {
      fetch("/api/more?page=" + page)
        .then(r => r.text())
        .then(html => {
          document.getElementById("feed")
            .insertAdjacentHTML("beforeend", html);
          page++;
        });
    }
  }, { threshold: 0.1 });
  observer.observe(sentinel);
</script>
{% endhighlight %}
</div>
</div>

