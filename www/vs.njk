<div class="vs-pair">
<h3>Morph after fetch</h3>
<p class="desc"></p>
<div>
<div class="vs-label">hyperscript</div>

{% highlight "html" %}
<button _="on click
            fetch /api/component
            morph #target to the result">
  Refresh
</button>
{% endhighlight %}
</div>
<div>
<div class="vs-label">JavaScript</div>

{% highlight "html" %}
<button id="refresh">Refresh</button>
<script>
  // Requires a morph library (idiomorph, morphdom, etc.)
  document.getElementById("refresh")
    .addEventListener("click", async () => {
      const resp = await fetch("/api/component");
      const html = await resp.text();
      const template = document.createElement("template");
      template.innerHTML = html;
      Idiomorph.morph(
        document.getElementById("target"),
        template.content,
        { morphStyle: "outerHTML" }
      );
    });
</script>
{% endhighlight %}
</div>
<div class="vs-demo">
<div class="vs-label">Try it</div>
<button _="on click fetch /virtual/component then morph #vs-morph-target to the result">Refresh</button>
<div id="vs-morph-target" style="margin-top:0.5rem; padding:8px; border:1px solid var(--border); border-radius:var(--radius)">
    <strong>Macintosh 128K</strong> - click Refresh to morph
</div>
</div>
