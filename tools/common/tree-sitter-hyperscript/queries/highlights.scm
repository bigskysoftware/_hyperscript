; Feature keywords (bold in most themes)
(feature_keyword) @keyword

; Command keywords
(command_keyword) @keyword

; Control flow
(control_keyword) @keyword

; Modifiers (contextual keywords - slightly muted)
(modifier) @keyword.modifier

; Type names
(type_name) @type.builtin

; Strings
(string) @string
(template_string) @string

; Numbers
(number) @number

; Booleans and null
(boolean) @constant.builtin

; Comments
(comment) @comment

; CSS references
(css_class) @tag
(css_id) @tag
(css_selector) @tag

; Attribute and style references
(attribute_ref) @attribute
(style_ref) @attribute

; Operators
(operator) @operator

; Punctuation
(punctuation) @punctuation.bracket

; Identifiers
(identifier) @variable
